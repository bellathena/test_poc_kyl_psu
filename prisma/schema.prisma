generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator prismabox {
  provider                    = "prismabox"
  output                      = "../generated/prismabox"
  inputModel                  = "true"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
}

datasource db {
  provider = "postgresql"
}

enum RequestType {
  FIND_FULLTEXT_4U
  ITHENTICATE
  BOOK_DELIVERY
  ILL
  ACADEMIC_PUBLICATION_DISSEMINATION
}

enum StatusRequest {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

model Requests {
  request_id       String       @id @default(uuid())

  request_number   String       @unique

  title            String
  request_type     RequestType

  requester_name   String
  requester_email  String

  detail           String

  status           StatusRequest @default(PENDING)
  admin_response   String?

  is_delete        Boolean      @default(false)

  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  created_by       String?
  user             Users?       @relation(fields: [created_by], references: [user_id])

  status_history   RequestStatusHistory[]

  @@index([request_number])
  @@index([request_type])
  @@index([status])
}

model Users {
  user_id        String    @id @default(uuid())

  username       String    @unique
  password_hash  String

  first_name     String
  last_name      String

  role           UserRole  @default(USER)

  is_active      Boolean   @default(true)
  is_delete      Boolean   @default(false)

  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  requests       Requests[]
  status_history RequestStatusHistory[]
}

model RequestStatusHistory {
  history_id   String        @id @default(uuid())

  request_id   String
  request      Requests      @relation(fields: [request_id], references: [request_id])

  old_status   StatusRequest
  new_status   StatusRequest

  changed_by   String?
  changed_by_user Users?     @relation(fields: [changed_by], references: [user_id])

  remark       String?

  created_at   DateTime      @default(now())

  @@index([request_id])
  @@index([changed_by])
  @@index([created_at])
}
